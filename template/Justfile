# Test threads for nextest. Override with `just jobs=8 test` or JOBS=8.
jobs := env_var_or_default("JOBS", "16")

# List available recipes.
default:
    @just --list

# `just` itself isn't here â€” bootstrap it with `cargo install just`.
# Install the dev tools `just check` (and the optional recipes) need.
setup:
    #!/usr/bin/env bash
    set -euo pipefail
    rustup toolchain install nightly --component rustfmt{% if miri %},miri{% endif %}
    tools=(cargo-nextest cargo-deny cargo-machete typos-cli)
    {% if coverage %}tools+=(cargo-llvm-cov){% endif %}
    {% if careful != "off" %}tools+=(cargo-careful){% endif %}
    {% if fuzzing %}tools+=(cargo-fuzz){% endif %}
    {% if feature_powerset %}tools+=(cargo-hack){% endif %}
    cargo install --locked "${tools[@]}"

# Full local check suite (mirrors the core CI).
check: _check-tools fmt clippy build test doc deny machete typos{% if benchmarks %} bench-build{% endif %}

# Check formatting (nightly rustfmt).
fmt:
    cargo +nightly fmt --all -- --check

# Apply formatting (nightly rustfmt).
fmt-fix:
    cargo +nightly fmt --all

# Lint with clippy, denying warnings.
clippy:
    cargo clippy --all-targets --all-features -- -D warnings

# Apply clippy's machine-applicable suggestions.
clippy-fix:
    cargo clippy --fix --all-targets --all-features --allow-dirty --allow-staged

# Build all targets in release mode.
build: _lockfile
    cargo build --release --all-targets --locked

# Run unit, integration, and doc tests.
test: _lockfile
    cargo nextest run --all-targets --all-features --locked --test-threads={% raw %}{{jobs}}{% endraw %}
    cargo test --doc --all-features --locked

# Build the documentation, denying warnings (mirrors CI and docs.rs).
doc: _lockfile
    RUSTDOCFLAGS="-D warnings" cargo doc --no-deps --all-features --document-private-items --locked

# Check the dependency tree (advisories, licenses, bans, sources).
deny:
    cargo deny check

# Find unused dependencies.
machete:
    cargo machete

# Check spelling.
typos:
    typos

# Lint the GitHub Actions workflows (also enforced by the actionlint CI job).
actionlint:
    actionlint

# Actions ship SHA-pinned for supply-chain safety; run this once if you'd rather
# track tags. Prefers the moving major tag the action publishes (vN, or v0.N for
# 0.x) and falls back to the comment's exact version when no such tag exists.

# Revert every SHA-pinned action (@<sha> # vX.Y.Z) to a mutable tag ref.
unpin:
    #!/usr/bin/env bash
    set -euo pipefail
    find .github -type f \( -name '*.yml' -o -name '*.yaml' \) -print0 \
        | xargs -0 perl -i -pe '
            s{uses:(\s*)([^@\s]+)\@[0-9a-fA-F]{40}\s+\#\s+v?(\d+(?:\.\d+){0,2}\S*)}{
                my ($sp, $action, $ver) = ($1, $2, $3);
                (my $repo = $action) =~ s{(/[^/]+).*}{$1};
                my @p = split /\./, $ver;
                my $moving = $p[0] eq "0" ? "v$p[0].$p[1]" : "v$p[0]";
                my $hit = `git ls-remote --tags --quiet https://github.com/$repo refs/tags/$moving 2>/dev/null`;
                "uses:$sp$action\@" . (($hit ne "") ? $moving : "v$ver");
            }gxe'
    echo "Unpinned all actions to tag refs. Review with: git diff .github"
{% if benchmarks %}
# Compile-check benchmarks â€” what `just check` runs (CI never runs benches).
bench-build: _lockfile
    cargo bench --no-run --locked

# Run benchmarks (criterion). For local profiling only â€” not part of `just check`.
bench:
    cargo bench
{% endif -%}
{%- if coverage %}
# Generate an HTML coverage report and open it.
coverage:
    cargo llvm-cov --all-features --open nextest
{% endif -%}
{%- if miri %}
# Run tests under Miri to catch undefined behavior (slow; not in `just check`).
miri:
    cargo +nightly miri nextest run --all-features
{% endif -%}
{%- if careful != "off" %}
# Run tests under cargo-careful for extra runtime UB checks (nightly).
careful:
    cargo +nightly careful test --all-features
{% endif -%}
{%- if sanitizers %}
# sanitizers.yml runs the full address/leak/thread matrix on Linux; this is
# narrower on purpose, since LeakSanitizer is unsupported on macOS and TSan is
# flaky there, while ASan works everywhere. (just shows the last line below in
# `just --list`, so keep it a standalone summary.)
# Quick local AddressSanitizer smoke check on the host target.
sanitize:
    #!/usr/bin/env bash
    set -euo pipefail
    target=$(rustc -vV | sed -n 's|host: ||p')
    RUSTFLAGS="-Zsanitizer=address" RUSTDOCFLAGS="-Zsanitizer=address" \
        cargo +nightly test -Zbuild-std --all-features --target "$target"
{% endif -%}
{%- if fuzzing %}
# Run the fuzz target for 60s (requires cargo-fuzz + nightly).
fuzz:
    cargo +nightly fuzz run fuzz_target_1 -- -max_total_time=60
{% endif -%}
{%- if feature_powerset %}
# For a library, swap `--all-targets` for `--no-dev-deps` to catch missing
# `#[cfg(feature)]` gates that dev-deps would otherwise mask; it can't run under
# `--locked`, but cargo-hack restores Cargo.lock when done so the tree stays clean.
# Type-check every feature combination with cargo-hack (mirrors feature-powerset CI).
hack: _lockfile
    cargo hack --feature-powerset --locked check --all-targets
{% endif %}
# List unfinished work: todo!/unimplemented! macros and TODO-style comments.
todo:
    -rg 'todo!\(\)|unimplemented!\(\)' --iglob='!Justfile'
    -rg 'TODO|XXX|HACK|PERF|FIXME|BUG' --iglob='!Justfile'

# Ensure a Cargo.lock exists before the `--locked` recipes run (hidden helper).
# cargo-generate ships no lock, so a fresh checkout has none until the first
# build; without this, `just build`/`test`/`doc`/`bench-build` would fail on a
# clean tree. A no-op once a lock is committed, so `--locked`'s drift detection
# stays intact. `just` runs a shared dependency only once, so `just check`
# triggers this a single time.
_lockfile:
    [ -f Cargo.lock ] || cargo generate-lockfile

# Report any tools `just check` needs that aren't installed (hidden helper).
_check-tools:
    #!/usr/bin/env bash
    set -euo pipefail
    missing=()
    command -v cargo-nextest >/dev/null 2>&1 || missing+=("cargo-nextest")
    command -v cargo-deny    >/dev/null 2>&1 || missing+=("cargo-deny")
    command -v cargo-machete >/dev/null 2>&1 || missing+=("cargo-machete")
    command -v typos         >/dev/null 2>&1 || missing+=("typos-cli")
    cargo +nightly fmt --version >/dev/null 2>&1 || missing+=("nightly rustfmt")
    if [ ${#missing[@]} -ne 0 ]; then
        echo "Missing tools: ${missing[*]}" >&2
        echo "Run \`just setup\` to install all (or install them manually)." >&2
        exit 1
    fi
